# Database (Neon Postgres - pooled connection string)
# Get from Neon Dashboard → Connection Details → Pooled connection string
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Admin Auth (protects /admin/* routes with HTTP Basic Auth)
# Generate a strong password: openssl rand -base64 32
ADMIN_PASSWORD="your-super-secure-password-here"

# Optional: App URL for metadataBase (replace with your domain)
# NEXT_PUBLIC_APP_URL="https://yourdomain.com"