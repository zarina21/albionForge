9:["$","$L14",null,{"builds":[{"id":"cmqg1peqb00005wvadi8tjg1j","title":"Battleaxe Solo Open World","slug":"battleaxe-solo-open-world","description":"High sustain melee DPS build for solo open world content. Infinite healing from Mercenary Jacket + Battleaxe Q combo.","contentType":"solo_open_world","partySize":"1","role":"Sustain DPS","weaponLine":"Axe","mainHand":"Battleaxe","offHand":"Torch","head":"Hunter Hood","chest":"Mercenary Jacket","shoes":"Soldier Boots","cape":"Thetford Cape","bag":null,"mount":null,"food":"Roast Pork","potion":"Healing Potion","tierRecommended":4,"enchantRecommended":0,"ipMin":700,"budgetLevel":"cheap","difficulty":"easy","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:14.742Z","author":null,"status":"active","sourceType":"hybrid","isRecommended":true,"isPopular":true,"isCheap":false,"isOutdated":false,"pros":"Excellent sustain, cheap to build, great for fame farming, easy to play","cons":"Low burst damage, vulnerable to ganks, predictable playstyle","combo":"Q (heal) -> W (armor pierce) -> auto attacks -> E (execute)","strongAgainst":"Mobs, solo dungeons, open world camps","weakAgainst":"Kite builds, ranged DPS in PvP","notes":"Mercenary Jacket + Battleaxe Q gives infinite sustain for solo content. Best budget build for new players.","createdAt":"$D2026-06-16T02:51:14.771Z","updatedAt":"$D2026-06-16T02:51:17.201Z"},{"id":"cmqg1pfyr00085wvazjz93dfx","title":"Bear Paws Ganking","slug":"bear-paws-ganking","description":"High burst ganking build using Bear Paws. Popular in recent PvP data.","contentType":"ganking","partySize":"2","role":"Ganker","weaponLine":"Axe","mainHand":"Bear Paws","offHand":null,"head":"Fiend Cowl","chest":"Assassin Jacket","shoes":"Royal Sandals","cape":"Thetford Cape","bag":null,"mount":null,"food":"Beef Stew","potion":"Poison Potion","tierRecommended":7,"enchantRecommended":1,"ipMin":1200,"budgetLevel":"expensive","difficulty":"hard","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:16.369Z","author":null,"status":"experimental","sourceType":"pvp_stats","isRecommended":false,"isPopular":true,"isCheap":false,"isOutdated":false,"pros":"Extremely high burst, good chase potential, strong in coordinated ganks","cons":"Expensive, requires coordination, falls off if initial burst fails","combo":"E (leap) -> W (bleed) -> auto attacks -> Royal Sandals reset","strongAgainst":"Gatherers, solo players, transporters","weakAgainst":"Tanks, healers, organized groups","notes":"Coordinate with a partner for best results. Use Fiend Cowl to purge defensives.","createdAt":"$D2026-06-16T02:51:16.371Z","updatedAt":"$D2026-06-16T02:51:16.371Z"},{"id":"cmqg1pey300015wvaq28yd6ty","title":"Bloodletter Solo Mists","slug":"bloodletter-solo-mists","description":"High burst mobility build for solo mists. Assassin playstyle with strong escape potential.","contentType":"solo_mists","partySize":"1","role":"Mobility build","weaponLine":"Dagger","mainHand":"Bloodletter","offHand":"Mistcaller","head":"Mage Cowl","chest":"Assassin Jacket","shoes":"Soldier Boots","cape":"Thetford Cape","bag":null,"mount":null,"food":"Beef Stew","potion":"Healing Potion","tierRecommended":6,"enchantRecommended":1,"ipMin":1100,"budgetLevel":"medium","difficulty":"medium","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:15.041Z","author":null,"status":"experimental","sourceType":"hybrid","isRecommended":true,"isPopular":true,"isCheap":false,"isOutdated":false,"pros":"High burst damage, great mobility, strong escape potential, good in 1v1","cons":"Squishy, requires good positioning, punished hard by mistakes","combo":"Q -> W -> E -> auto attacks -> reset with Q","strongAgainst":"Immobile builds, healers in 1v1","weakAgainst":"Tanks, Nature Staff sustain, chain CC","notes":"Best played with Assassin Spike W for extra burst. Save boots for escape.","createdAt":"$D2026-06-16T02:51:15.051Z","updatedAt":"$D2026-06-16T02:51:15.051Z"},{"id":"cmqg1pg4j00095wvax7kb36wg","title":"Bow Solo Mists Cheap","slug":"bow-solo-mists-cheap","description":"Budget-friendly bow build for solo mists. Kite and sustain through Mercenary Jacket.","contentType":"solo_mists","partySize":"1","role":"Kite DPS","weaponLine":"Bow","mainHand":"Regular Bow","offHand":null,"head":"Hunter Hood","chest":"Mercenary Jacket","shoes":"Soldier Boots","cape":"Thetford Cape","bag":null,"mount":null,"food":"Beef Stew","potion":"Healing Potion","tierRecommended":4,"enchantRecommended":0,"ipMin":700,"budgetLevel":"cheap","difficulty":"easy","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:16.575Z","author":null,"status":"active","sourceType":"market_calculated","isRecommended":false,"isPopular":true,"isCheap":true,"isOutdated":false,"pros":"Very cheap, good kiting potential, easy to play","cons":"Low burst, outscaled by expensive builds, predictable","combo":"Q (slow) -> auto attacks -> W (damage) -> E (escape)","strongAgainst":"Melee builds, open world PvE","weakAgainst":"One-shot builds, mobile assassins","notes":"The cheapest viable build for mists. Focus on positioning and kiting.","createdAt":"$D2026-06-16T02:51:16.579Z","updatedAt":"$D2026-06-16T02:51:17.784Z"},{"id":"cmqg1pfnw00075wva3wfg22em","title":"Double Bladed Miner Escape","slug":"double-bladed-miner-escape","description":"Fast gathering build focused on escape. Best for gathering in dangerous zones.","contentType":"solo_gathering","partySize":"1","role":"Escape gatherer","weaponLine":"Quarterstaff","mainHand":"Double Bladed Staff","offHand":null,"head":"Miner Cap","chest":"Miner Garb","shoes":"Miner Workboots","cape":"Fort Sterling Cape","bag":"Gathering Bag","mount":"Giant Stag","food":"Pork Pie","potion":"Invisibility Potion","tierRecommended":5,"enchantRecommended":0,"ipMin":800,"budgetLevel":"medium","difficulty":"easy","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:15.975Z","author":null,"status":"active","sourceType":"manual","isRecommended":true,"isPopular":false,"isCheap":false,"isOutdated":false,"pros":"Fast gathering, great escape, cheap investment","cons":"Zero PvP power, relies on avoiding fights","combo":"Q (speed burst) -> W (knockback) -> E (stun) -> run","strongAgainst":"Ganking attempts, dangerous zones","weakAgainst":"Coordinated gank groups, purges","notes":"Double Bladed Staff gives best mobility for escape. Always carry Invis potion for Black Zone.","createdAt":"$D2026-06-16T02:51:15.980Z","updatedAt":"$D2026-06-16T02:51:15.980Z"},{"id":"cmqg1pg9a000a5wvakg1wxmy5","title":"Fire Staff Arena DPS","slug":"fire-staff-arena-dps","description":"Ranged DPS for Crystal Arena. Consistent sustained damage with good AoE.","contentType":"crystal_arena_5v5","partySize":"5","role":"Ranged DPS","weaponLine":"Fire Staff","mainHand":"Great Fire Staff","offHand":null,"head":"Cleric Cowl","chest":"Cleric Robe","shoes":"Scholar Sandals","cape":"Thetford Cape","bag":null,"mount":null,"food":"Omelette","potion":"Resistance Potion","tierRecommended":7,"enchantRecommended":1,"ipMin":1100,"budgetLevel":"medium","difficulty":"medium","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:16.750Z","author":null,"status":"active","sourceType":"manual","isRecommended":true,"isPopular":false,"isCheap":false,"isOutdated":false,"pros":"Good sustained damage, strong AoE, safe range","cons":"Low mobility, vulnerable to dives, skill-shot dependent","combo":"Q (fireball) -> W (AoE) -> E (knockback) -> auto attacks","strongAgainst":"Clumped teams, defensive compositions","weakAgainst":"Dive comps, mobile assassins, interrupts","notes":"Stay at max range and poke. Use E to peel divers off you.","createdAt":"$D2026-06-16T02:51:16.750Z","updatedAt":"$D2026-06-16T02:51:16.750Z"},{"id":"cmqg1pfc600045wvapgni7pq5","title":"Great Holy Crystal Arena","slug":"great-holy-crystal-arena","description":"Primary healer build for Crystal Arena 5v5. Strong burst heals with good mana sustain.","contentType":"crystal_arena_5v5","partySize":"5","role":"Healer","weaponLine":"Holy Staff","mainHand":"Great Holy Staff","offHand":null,"head":"Cleric Cowl","chest":"Cleric Robe","shoes":"Scholar Sandals","cape":"Lymhurst Cape","bag":null,"mount":null,"food":"Omelette","potion":"Resistance Potion","tierRecommended":7,"enchantRecommended":1,"ipMin":1200,"budgetLevel":"medium","difficulty":"medium","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:15.558Z","author":null,"status":"active","sourceType":"manual","isRecommended":true,"isPopular":false,"isCheap":false,"isOutdated":false,"pros":"Strong burst heals, good mana sustain, team fight enabler","cons":"Vulnerable when focused, predictable, expensive for full build","combo":"W (big heal) -> E (AoE heal) -> Q (single target) -> Holy Orb","strongAgainst":"Burst comps, sustained damage teams","weakAgainst":"Dive comps, purge, interrupt chains","notes":"Positioning is key. Stay behind your tank and use Scholar Sandals for mana.","createdAt":"$D2026-06-16T02:51:15.558Z","updatedAt":"$D2026-06-16T02:51:15.558Z"},{"id":"cmqg1pf3o00025wvawm2ylvbd","title":"Great Nature Solo Sustain","slug":"great-nature-solo-sustain","description":"Nearly unkillable sustain build for solo mists. Wins through attrition.","contentType":"solo_mists","partySize":"1","role":"Sustain DPS","weaponLine":"Nature Staff","mainHand":"Great Nature Staff","offHand":null,"head":"Mage Cowl","chest":"Cleric Robe","shoes":"Soldier Boots","cape":"Martlock Cape","bag":null,"mount":null,"food":"Omelette","potion":"Resistance Potion","tierRecommended":6,"enchantRecommended":1,"ipMin":1000,"budgetLevel":"medium","difficulty":"medium","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:15.250Z","author":null,"status":"active","sourceType":"hybrid","isRecommended":true,"isPopular":true,"isCheap":false,"isOutdated":false,"pros":"Almost unkillable, great sustain, strong 1v1 potential","cons":"Low damage output, long fights, weak against purge","combo":"Q (thorn) -> W (heal) -> E (root) -> auto attacks -> reposition","strongAgainst":"Melee DPS, brawlers, sustained fights","weakAgainst":"One-shot builds, purge abilities, mobile assassins","notes":"Stay alive and win through attrition. Use Cleric Robe to counter burst.","createdAt":"$D2026-06-16T02:51:15.252Z","updatedAt":"$D2026-06-16T02:51:17.433Z"},{"id":"cmqg1pfg500055wvaq5eo8k57","title":"Grovekeeper ZvZ Engage Tank","slug":"grovekeeper-zvz-engage-tank","description":"The best engage tool in ZvZ. Massive AoE stun sets up wipes for your clap DPS.","contentType":"zvz","partySize":"20","role":"Engage Tank","weaponLine":"Hammer","mainHand":"Grovekeeper","offHand":null,"head":"Judicator Helmet","chest":"Guardian Armor","shoes":"Hunter Shoes","cape":"Martlock Cape","bag":null,"mount":null,"food":"Pork Omelette","potion":"Resistance Potion","tierRecommended":8,"enchantRecommended":2,"ipMin":1500,"budgetLevel":"expensive","difficulty":"hard","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:15.700Z","author":null,"status":"active","sourceType":"manual","isRecommended":true,"isPopular":false,"isCheap":false,"isOutdated":false,"pros":"Best engage in ZvZ, massive AoE stun, sets up wipes","cons":"Very expensive, requires good call, single-use engage","combo":"E (AoE stun) -> W (slow/armor pierce) -> Q -> reposition","strongAgainst":"Clumped teams, defensive formations","weakAgainst":"Spread compositions, kiting, Morgana cape","notes":"Must be called by shotcaller. Deadly combo with Permafrost or Clap DPS.","createdAt":"$D2026-06-16T02:51:15.701Z","updatedAt":"$D2026-06-16T02:51:15.701Z"},{"id":"cmqg1pgdy000b5wvab9a2243p","title":"Mace Defensive Tank","slug":"mace-defensive-tank","description":"Tank for Crystal Arena with heavy defensive tools and peel for your backline.","contentType":"crystal_arena_5v5","partySize":"5","role":"Defensive Tank","weaponLine":"Mace","mainHand":"Heavy Mace","offHand":"Shield","head":"Guardian Helmet","chest":"Guardian Armor","shoes":"Hunter Shoes","cape":"Martlock Cape","bag":null,"mount":null,"food":"Pork Omelette","potion":"Resistance Potion","tierRecommended":7,"enchantRecommended":1,"ipMin":1300,"budgetLevel":"medium","difficulty":"medium","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:16.916Z","author":null,"status":"active","sourceType":"manual","isRecommended":true,"isPopular":false,"isCheap":false,"isOutdated":false,"pros":"Strong peel, good CC, very tanky","cons":"Low damage, needs team follow-up","combo":"W (stun) -> Q (slow) -> E (armor pierce) -> reposition","strongAgainst":"Melee DPS, dive compositions","weakAgainst":"Kite comps, sustained damage","notes":"Protect your healer and DPS. Use Guardian Armor for team defensive buff.","createdAt":"$D2026-06-16T02:51:16.918Z","updatedAt":"$D2026-06-16T02:51:16.918Z"},{"id":"cmqg1pf8000035wvakbq22o4x","title":"One-handed Cursed Corrupted","slug":"one-handed-cursed-corrupted","description":"True damage kite build for corrupted dungeons. Stack curses then detonate.","contentType":"corrupted_dungeons","partySize":"1","role":"Kite DPS","weaponLine":"Cursed Staff","mainHand":"One-handed Cursed Staff","offHand":"Shield","head":"Hunter Hood","chest":"Cleric Robe","shoes":"Soldier Boots","cape":"Thetford Cape","bag":null,"mount":null,"food":"Beef Stew","potion":"Healing Potion","tierRecommended":5,"enchantRecommended":0,"ipMin":900,"budgetLevel":"cheap","difficulty":"medium","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:15.408Z","author":null,"status":"active","sourceType":"hybrid","isRecommended":true,"isPopular":true,"isCheap":false,"isOutdated":false,"pros":"True damage, cheap build, strong against tanks","cons":"Skill-shot dependent, vulnerable to interrupts","combo":"Q (curse) -> stacks -> E (detonate) -> W (fear)","strongAgainst":"Tanks, high armor builds, sustain","weakAgainst":"Mobility builds, interrupts, purge","notes":"Stack curses then detonate for massive true damage. Shield gives survivability.","createdAt":"$D2026-06-16T02:51:15.408Z","updatedAt":"$D2026-06-16T02:51:17.567Z"},{"id":"cmqg1pfk200065wvaq413ue84","title":"Permafrost ZvZ Clap DPS","slug":"permafrost-zvz-clap-dps","description":"Highest clap damage in ZvZ. Freeze, slow and massive AoE burst.","contentType":"zvz","partySize":"20","role":"Clap DPS","weaponLine":"Frost Staff","mainHand":"Permafrost Prism","offHand":null,"head":"Royal Cowl","chest":"Scholar Robe","shoes":"Cleric Sandals","cape":"Morgana Cape","bag":null,"mount":null,"food":"Beef Stew","potion":"Energy Potion","tierRecommended":8,"enchantRecommended":2,"ipMin":1500,"budgetLevel":"expensive","difficulty":"hard","patchVersion":"latest","lastVerifiedAt":"$D2026-06-16T02:51:15.841Z","author":null,"status":"active","sourceType":"manual","isRecommended":true,"isPopular":false,"isCheap":false,"isOutdated":false,"pros":"Highest clap damage in ZvZ, slow + damage combo","cons":"Extremely expensive, needs setup, vulnerable to dives","combo":"E (freeze/slow) -> W (damage) -> Q -> Scholar Robe burst","strongAgainst":"Clumped teams, static formations","weakAgainst":"Dive comps, spread, interrupt chains","notes":"Coordinate with engage tank. Royal Cowl gives cooldown reduction for more claps.","createdAt":"$D2026-06-16T02:51:15.842Z","updatedAt":"$D2026-06-16T02:51:15.842Z"}],"resources":[],"guides":[]}]
